rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- ENTITY VALIDATIONS ---

    function isValidUserHistory(data) {
      return data.id is string &&
             data.userId == request.auth.uid &&
             data.timestamp is number &&
             data.jobTitle is string &&
             data.jobTitle.size() <= 200 &&
             data.jdText is string &&
             data.jdText.size() <= 20000;
    }

    function isValidMasterCV(data) {
      return data.userId == request.auth.uid &&
             data.htmlContent is string &&
             data.htmlContent.size() <= 100000;
    }

    function isValidWaitlist(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.timestamp is number;
    }

    // --- COLLECTION MATCHES ---

    match /user_history/{historyId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(historyId) && isValidUserHistory(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidUserHistory(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.timestamp == resource.data.timestamp;
      allow delete: if isOwner(resource.data.userId);
    }

    match /master_cv/{userId} {
      allow get, write: if isOwner(userId) && (request.method != 'create' && request.method != 'update' || isValidMasterCV(request.resource.data));
    }

    match /waitlist/{waitlistId} {
      allow create: if isValidId(waitlistId) && isValidWaitlist(request.resource.data);
      // Waitlist data is private, only the system/admin should read it. No client read access for now.
      allow read: if false;
    }
  }
}
